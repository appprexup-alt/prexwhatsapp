        {
            "parameters": {
                "jsCode": "const response = $input.first().json;\nconst ctx = $('Prepare Context').item.json;\nlet aiText = response.choices?.[0]?.message?.content || '¡Hola! Gracias por contactar Residencial Alquimia. Un asesor te atenderá pronto.';\n\n// Limpiar respuesta\naiText = aiText.trim();\n\nreturn {\n  text: aiText,\n  phone: ctx.phone,\n  instance: ctx.instance,\n  leadId: ctx.leadId\n};"
            },
