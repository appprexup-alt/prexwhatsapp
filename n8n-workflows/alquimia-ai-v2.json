        {
            "parameters": {
                "jsCode": "const properties = $input.first().json;\nconst ctx = $('Chatbot Active?').item.json;\n\nconst props = Array.isArray(properties) \n  ? properties.map(p => `${p.lot_number}: ${p.area}m², $${p.price} USD${(p.features||[]).length ? ' - ' + p.features.join(', ') : ''}`).join('\\n')\n  : '';\n\nreturn {\n  leadId: ctx.leadId,\n  phone: ctx.phone,\n  instance: ctx.instance,\n  name: ctx.name,\n  properties: props,\n  currentMessage: ctx.content\n};"
            },
            "id": "prepare-ctx",
            "name": "Prepare Context",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                2000,
                100
