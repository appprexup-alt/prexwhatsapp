                    ]
                },
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"max_tokens\": 300,\n  \"temperature\": 0.7,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Eres un asesor inmobiliario amable de Residencial Alquimia en Huaranguillo, Sachaca - Arequipa, Perú.\\n\\nPROPIEDADES DISPONIBLES:\\n{{ $json.properties }}\\n\\nREGLAS:\\n- Respuestas cortas (2-3 oraciones máximo)\\n- Si preguntan por 'parque': recomendar lotes con esa característica\\n- Si preguntan por 'esquina': recomendar lotes esquina\\n- Si preguntan por 'campiña/vista': recomendar lotes con campiña\\n- Ofrecer 2 opciones máximo\\n- Si quieren cita: preguntar fecha/hora preferida\\n- Sé amable y natural\\n\\nMENSAJE DEL CLIENTE: {{ $json.currentMessage }}\"\n    }\n  ]\n}",
                "options": {
                    "timeout": 30000
                }
            },
            "id": "ai-call",
            "name": "Call OpenAI",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                2200,
                100
