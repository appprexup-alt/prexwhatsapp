                "jsCode": "const input = $input.first().json;\nconst body = input.body || input;\nconst data = body.data || body;\nconst message = data.message || {};\nconst key = data.key || {};\n\nconst instance_server_url = 'https://evolutionapi.kywia.com';\nconst instance_name = body.instance || 'prexup';\nconst instance_apikey = '2023bb74c1f985aa39f432fa165a27f4';\nconst message_id = key.id || '';\nconst user_number = key.remoteJid || body.sender || '';\nconst phone = user_number.replace('@s.whatsapp.net', '').replace('@g.us', '');\nconst pushName = data.pushName || body.pushName || 'Cliente';\nconst direction = key.fromMe ? 'outbound' : 'inbound';\n\nlet message_content_type = 'text';\nlet message_content = '';\n\nif (message.conversation) {\n  message_content = message.conversation;\n} else if (message.extendedTextMessage && message.extendedTextMessage.text) {\n  message_content = message.extendedTextMessage.text;\n} else if (message.buttonsResponseMessage) {\n  message_content = message.buttonsResponseMessage.selectedDisplayText || '';\n} else if (message.listResponseMessage) {\n  message_content = message.listResponseMessage.title || '';\n} else if (message.imageMessage) {\n  message_content_type = 'image';\n  message_content = message.imageMessage.caption || '';\n} else if (message.audioMessage) {\n  message_content_type = 'audio';\n  message_content = 'Audio';\n} else if (message.videoMessage) {\n  message_content_type = 'video';\n  message_content = message.videoMessage.caption || '';\n} else if (body.text) {\n  message_content = body.text;\n}\n\nconst isOutbound = key.fromMe === true;\nconst isGroup = user_number.includes('@g.us');\nconst isEmpty = !message_content && message_content_type === 'text';\n\nif (isOutbound || isGroup) {\n  return { skip: true, reason: isOutbound ? 'outbound' : 'group' };\n}\n\nconst safeName = pushName ? String(pushName).replace(/'/g, \"''\").substring(0, 100) : 'WA ' + phone;\nconst safeContent = String(message_content).trim().replace(/'/g, \"''\").substring(0, 1000);\n\nreturn {\n  skip: false,\n  instance_server_url,\n  instance_name,\n  instance_apikey,\n  message_id,\n  message_content_type,\n  message_content: safeContent,\n  phone,\n  user_number,\n  lead_name: safeName,\n  direction\n};"
            },
