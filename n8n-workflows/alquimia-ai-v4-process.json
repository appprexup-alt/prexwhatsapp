            "parameters": {
                "jsCode": "const input = $input.first().json;\nconst body = input.body || input;\n\n// Calcular delay en milisegundos (100 segundos)\nconst delayMs = (body.delay_seconds || 100) * 1000;\n\nreturn {\n  sessionId: body.session_id,\n  phone: body.phone,\n  delayMs: delayMs,\n  instance: body.instance || 'prexup'\n};"
            },
            "id": "parse-trigger",
            "name": "Parse Trigger",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                400,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "// Esperar usando setTimeout antes de continuar\nconst ctx = $input.first().json;\nconst delayMs = ctx.delayMs || 100000;\n\n// Usar promise para esperar\nawait new Promise(resolve => setTimeout(resolve, delayMs));\n\nreturn {\n  sessionId: ctx.sessionId,\n  phone: ctx.phone,\n  instance: ctx.instance\n};"
            },
