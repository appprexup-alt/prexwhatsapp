        {
            "parameters": {
                "jsCode": "const result = $input.first().json;\nconst triggerData = $('Wait 100s').item.json;\n\n// Parse if string\nlet session = result;\nif (typeof result === 'string') {\n  try {\n    session = JSON.parse(result);\n  } catch(e) {\n    return { skip: true, error: 'Parse error' };\n  }\n}\n\n// Check for errors or skip signal\nif (session.error || session.skip) {\n  return { skip: true, error: session.error || 'Already processed' };\n}\n\nreturn {\n  skip: false,\n  sessionId: session.session_id,\n  phone: session.phone,\n  leadId: session.lead_id,\n  name: session.lead_name || 'Cliente',\n  combinedMessage: session.combined_message,\n  messageCount: session.message_count,\n  messages: session.messages,\n  chatbotActive: session.chatbot_active !== false,\n  instance: triggerData.instance\n};"
            },
