        {
            "parameters": {
                "jsCode": "const messages = $('Get Conversation History').first().json;\nconst properties = $input.first().json;\nconst leadData = $('Should AI Respond?').item.json;\n\n// Format conversation history\nconst history = Array.isArray(messages) ? messages.reverse().map(m => \n  `${m.sender === 'client' ? 'Cliente' : 'Asistente'}: ${m.content}`\n).join('\\n') : '';\n\n// Format available properties\nconst propList = Array.isArray(properties) ? properties.map(p => \n  `- ${p.lot_number}: ${p.area}m², $${p.price} USD, Características: ${(p.features || []).join(', ')}`\n).join('\\n') : 'No hay propiedades disponibles';\n\nreturn {\n  leadId: leadData.leadId,\n  phone: leadData.phone,\n  instance: leadData.instance,\n  currentMessage: leadData.content,\n  conversationHistory: history,\n  availableProperties: propList,\n  propertiesData: properties\n};"
            },
