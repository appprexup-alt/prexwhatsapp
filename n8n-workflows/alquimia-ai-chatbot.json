            "typeVersion": 1,
            "position": [
                300,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "// Parse Evolution API webhook data\nconst payload = $input.first().json;\n\n// Only process message events\nif (payload.event !== 'messages.upsert') {\n  return { skip: true, reason: 'not_message' };\n}\n\nconst data = payload.data;\nconst key = data.key;\nconst jid = key?.remoteJid || '';\n\n// Skip groups and broadcasts\nif (!jid || jid.includes('@g.us') || jid === 'status@broadcast') {\n  return { skip: true, reason: 'group_or_broadcast' };\n}\n\n// Skip own messages (agent responses)\nif (key.fromMe) {\n  return { skip: true, reason: 'own_message' };\n}\n\nconst phone = jid.split('@')[0].replace(/\\\\D/g, '');\nconst pushName = data.pushName || 'Cliente';\nconst msg = data.message || {};\nconst instance = payload.instance;\n\n// Extract content\nlet content = '';\nlet isAudio = false;\n\nif (msg.conversation) {\n  content = msg.conversation;\n} else if (msg.extendedTextMessage?.text) {\n  content = msg.extendedTextMessage.text;\n} else if (msg.audioMessage) {\n  content = '[AUDIO]';\n  isAudio = true;\n} else if (msg.imageMessage) {\n  content = msg.imageMessage.caption || '[Imagen]';\n} else {\n  content = '[Mensaje]';\n}\n\nreturn {\n  skip: false,\n  phone: phone,\n  pushName: pushName,\n  content: content,\n  isAudio: isAudio,\n  instance: instance,\n  timestamp: new Date().toISOString(),\n  rawMessage: msg\n};"
            },
            "id": "parse-message",
            "name": "Parse Message",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                500,
                300
            ]
        },
        {
            "parameters": {
