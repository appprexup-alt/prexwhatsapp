            "id": "webhook",
            "name": "Webhook",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 2,
            "position": [
                200,
                300
            ],
            "webhookId": "alquimia-v4"
        },
        {
            "parameters": {
                "jsCode": "const body = $input.first().json;\n\n// Accept any message event\nif (!body.event || !body.event.includes('message')) {\n  if (!body.data) return { skip: true };\n}\n\nconst data = body.data || body;\nconst key = data.key || {};\nlet jid = key.remoteJid || data.remoteJid || '';\n\n// Skip groups, broadcasts and own messages\nif (!jid || jid.includes('@g.us') || jid === 'status@broadcast' || key.fromMe) {\n  return { skip: true };\n}\n\nconst phone = jid.split('@')[0];\nconst msg = data.message || {};\nlet content = msg.conversation || msg.extendedTextMessage?.text || data.body || '';\nlet isAudio = !!msg.audioMessage;\n\nif (isAudio) content = '[Audio recibido]';\nif (!content && msg.imageMessage) content = msg.imageMessage.caption || '[Imagen]';\nif (!content && msg.videoMessage) content = msg.videoMessage.caption || '[Video]';\nif (!content && msg.documentMessage) content = '[Documento]';\nif (!content) content = '[Mensaje]';\n\nconst instance = body.instance || body.instanceName || 'prexup';\n\nreturn {\n  skip: false,\n  phone,\n  name: data.pushName || 'Cliente',\n  content,\n  isAudio,\n  instance,\n  timestamp: Date.now()\n};"
            },
