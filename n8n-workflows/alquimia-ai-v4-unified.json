        {
            "parameters": {
                "jsCode": "const result = $input.first().json;\nconst waitData = $('Wait 100s').item.json;\n\n// Parse if string\nlet session = result;\nif (typeof result === 'string') {\n  try { session = JSON.parse(result); } catch(e) { return { skip: true }; }\n}\n\n// Check for errors\nif (session.error || session.skip) {\n  return { skip: true };\n}\n\nreturn {\n  skip: false,\n  sessionId: session.session_id,\n  phone: session.phone,\n  leadId: session.lead_id,\n  name: session.lead_name || 'Cliente',\n  combinedMessage: session.combined_message,\n  messageCount: session.message_count,\n  chatbotActive: session.chatbot_active !== false,\n  instance: waitData.instance\n};"
            },
            "id": "process-session",
            "name": "Process Session",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1800,
