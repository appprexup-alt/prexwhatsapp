        {
            "parameters": {
                "jsCode": "// WAIT 100 SECONDS before continuing\n// This allows more messages to be stacked\nconst ctx = $input.first().json;\nconst waitSeconds = ctx.secondsRemaining || 100;\n\n// Wait using setTimeout\nawait new Promise(resolve => setTimeout(resolve, waitSeconds * 1000));\n\nreturn {\n  sessionId: ctx.sessionId,\n  phone: ctx.phone,\n  instance: ctx.instance\n};"
            },
            "id": "wait-timer",
