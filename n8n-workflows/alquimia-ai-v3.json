        {
            "parameters": {
                "jsCode": "const result = $input.first().json;\nconst msgData = $('Parse Message').item.json;\n\nconst lead = Array.isArray(result) && result.length > 0 ? result[0] : result;\n\nreturn {\n  ...msgData,\n  leadId: lead?.id || null,\n  chatbotActive: lead?.chatbot_active ?? true,\n  currentInterest: lead?.interest || '',\n  isNewLead: lead?.is_new || false,\n  assignedTo: lead?.assigned_to || null\n};"
            },
