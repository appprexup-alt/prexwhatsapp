            "id": "get-history",
            "name": "Get Chat History",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1800,
                300
            ],
            "alwaysOutputData": true
        },
        {
            "parameters": {
                "jsCode": "const properties = $('Get Properties').item.json;\nconst ctx = $('Chatbot Active?').item.json;\n\n// Get all messages from history\nconst historyItems = $('Get Chat History').all();\nlet messagesArray = [];\n\n// Handle different response formats\nif (historyItems.length > 0) {\n  const firstItem = historyItems[0].json;\n  if (Array.isArray(firstItem)) {\n    messagesArray = firstItem;\n  } else if (firstItem && typeof firstItem === 'object') {\n    messagesArray = historyItems.map(item => item.json);\n  }\n}\n\n// Get current date/time in Peru timezone\nconst now = new Date();\nconst peruTime = new Date(now.toLocaleString('en-US', { timeZone: 'America/Lima' }));\nconst today = peruTime.toLocaleDateString('es-PE', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });\nconst currentTime = peruTime.toLocaleTimeString('es-PE', { hour: '2-digit', minute: '2-digit' });\n\n// Format properties\nconst props = Array.isArray(properties) \n  ? properties.map(p => {\n      const features = (p.features || []).join(', ');\n      return `Lote ${p.lot_number}: ${p.area}m², $${p.price} USD${features ? ' - ' + features : ''}`;\n    }).join('\\n')\n  : 'No hay propiedades disponibles';\n\n// Format chat history - CRITICAL: This must be passed correctly\nconst validMessages = messagesArray.filter(m => m && m.content && m.content.trim());\n\n// Build conversation history string\nlet chatHistoryText = '';\nif (validMessages.length > 0) {\n  // Reverse to show oldest first (chronological order)\n  const orderedMessages = validMessages.slice().reverse();\n  chatHistoryText = orderedMessages.map(m => {\n    const role = m.sender === 'client' ? 'CLIENTE' : 'ASESOR';\n    return `[${role}]: ${m.content}`;\n  }).join('\\n');\n} else {\n  chatHistoryText = '(Primera conversación - sin historial previo)';\n}\n\nreturn {\n  sessionId: ctx.leadId,\n  leadId: ctx.leadId,\n  phone: ctx.phone,\n  instance: ctx.instance,\n  clientName: ctx.name,\n  properties: props,\n  chatHistory: chatHistoryText,\n  currentMessage: ctx.content,\n  assignedTo: ctx.assignedTo,\n  today,\n  currentTime,\n  messageCount: validMessages.length\n};"
            },
