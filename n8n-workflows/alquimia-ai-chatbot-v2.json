        {
            "parameters": {
                "jsCode": "const response = $input.first().json;\nconst ctx = $('Prepare Context').item.json;\nconst aiText = response.choices?.[0]?.message?.content || 'Gracias por contactarnos. Un asesor te atenderá pronto.';\n\nlet msgs = aiText.split('[SPLIT]').map(m => m.trim()).filter(m => m);\nif (msgs.length === 0) msgs = [aiText];\nif (msgs.length === 1) {\n  const sentences = aiText.split(/(?<=[.!?])\\s+/);\n  if (sentences.length > 1) msgs = sentences.slice(0, 3);\n}\n\nreturn msgs.map((text, i) => ({\n  text,\n  phone: ctx.phone,\n  instance: ctx.instance,\n  leadId: ctx.leadId,\n  index: i\n}));"
            },
