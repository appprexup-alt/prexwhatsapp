        {
            "parameters": {
                "jsCode": "const body = $input.first().json;\n\nif (body.event !== 'messages.upsert') {\n  return { skip: true, reason: 'not message event' };\n}\n\nconst data = body.data || {};\nconst key = data.key || {};\nconst jid = key.remoteJid || '';\n\nif (!jid || jid.includes('@g.us') || jid === 'status@broadcast' || key.fromMe) {\n  return { skip: true, reason: 'invalid chat' };\n}\n\nconst phone = jid.split('@')[0];\nconst msg = data.message || {};\nlet content = msg.conversation || msg.extendedTextMessage?.text || '';\nlet isAudio = !!msg.audioMessage;\n\nif (isAudio) content = '[Audio recibido]';\nif (!content && msg.imageMessage) content = msg.imageMessage.caption || '[Imagen]';\nif (!content) content = '[Mensaje]';\n\nconst hasKeyword = content.toLowerCase().includes('alquimia');\nconst instance = body.instance || body.instanceName || 'default';\n\nreturn {\n  skip: false,\n  phone,\n  content,\n  isAudio,\n  hasKeyword,\n  instance,\n  pushName: data.pushName || 'Cliente',\n  timestamp: Date.now()\n};"
            },
