        {
            "parameters": {
                "jsCode": "const messages = $('Get History').first().json;\nconst properties = $input.first().json;\nconst ctx = $('Should Respond?').item.json;\n\nconst history = Array.isArray(messages) \n  ? messages.reverse().map(m => `${m.sender === 'client' ? 'Cliente' : 'Asesor'}: ${m.content}`).join('\\n')\n  : '';\n\nconst props = Array.isArray(properties) \n  ? properties.map(p => `${p.lot_number}: ${p.area}m², $${p.price} USD - ${(p.features||[]).join(', ')}`).join('\\n')\n  : '';\n\nreturn {\n  leadId: ctx.leadId,\n  phone: ctx.phone,\n  instance: ctx.instance,\n  history,\n  properties: props,\n  currentMessage: ctx.content\n};"
            },
